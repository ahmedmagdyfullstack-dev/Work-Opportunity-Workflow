NODE_ENV=development
PORT=3000
APP_BASE_URL=http://localhost:3000
ADMIN_API_KEY=change-me

# Local default is SQLite. Production should use postgres.
DATABASE_TYPE=sqlite
DATABASE_URL=postgresql://opportunity:opportunity@localhost:5432/opportunity
SQLITE_PATH=./data/opportunity.sqlite

REDIS_URL=
QUEUE_MODE=inline

OPENAI_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TIMEOUT_MS=25000
AI_MODEL=openai/gpt-oss-20b:free
AI_REASONING_EFFORT=none
AI_MODE=rules

SEARCH_PROVIDER=manual
BRAVE_SEARCH_API_KEY=
SERPER_API_KEY=
SERPAPI_API_KEY=
GOOGLE_CUSTOM_SEARCH_API_KEY=
GOOGLE_CUSTOM_SEARCH_ENGINE_ID=

GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_PUBSUB_TOPIC=
GMAIL_WEBHOOK_TOKEN=

OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_TENANT_ID=
OUTLOOK_CLIENT_STATE=

WHATSAPP_PROVIDER=log
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_TO_NUMBER=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ALERT_TEMPLATE=job_search_alert
WHATSAPP_DIGEST_TEMPLATE=job_search_digest
WHATSAPP_TEMPLATE_LANGUAGE=en_US

NOTIFICATION_THRESHOLD=80
DIGEST_THRESHOLD=60
LINKEDIN_POST_MAX_AGE_DAYS=4
LINKEDIN_SCRAPE_ENABLED=false
LINKEDIN_SCRAPE_TIMEOUT_MS=10000
LINKEDIN_SCRAPE_MAX_BYTES=1500000
DIGEST_CRON=0 18 * * *
SEARCH_CRON=0 2,8,14,20 * * *
